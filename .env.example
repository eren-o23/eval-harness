# Copy to .env and fill in. .env is gitignored; never commit real keys.

# Required for llm_judge evaluators using anthropic/* models (examples/evals.yaml).
ANTHROPIC_API_KEY=sk-ant-...

# Only needed if you point an llm_judge at an openai/* model.
# OPENAI_API_KEY=sk-...

# Only needed for other OpenAI-compatible providers (provider/model in the config),
# e.g. groq/llama3 -> GROQ_BASE_URL (+ GROQ_API_KEY if the endpoint requires one).
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_API_KEY=
